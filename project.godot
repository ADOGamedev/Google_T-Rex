;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[  ]
_global_script_class_icons={
}

[application]

config/name="Dinosaurio de google"
run/main_scene="res://main.tscn"
config/icon="res://dinosaurio_192x.png"
